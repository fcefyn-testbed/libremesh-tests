#!/usr/bin/env python3
"""
labgrid-dut-proxy - SSH ProxyCommand for DUT access via VLAN 200.

All LibreMesh DUTs share VLAN 200. This script forwards the SSH connection
through labgrid-bound-connect bound to the vlan200 interface.

Usage: labgrid-dut-proxy <device-id> <host> <port>
  e.g. labgrid-dut-proxy librerouter-1 10.13.200.77 22

Requires: labgrid-bound-connect in /usr/local/sbin/
Sudoers: ALL ALL = NOPASSWD: /usr/local/sbin/labgrid-dut-proxy
"""

import os
import sys

VLAN_MESH = 200
LABGRID_BOUND_CONNECT = "/usr/local/sbin/labgrid-bound-connect"


def main() -> int:
    if len(sys.argv) != 4:
        print("Usage: labgrid-dut-proxy <device-id> <host> <port>", file=sys.stderr)
        print("  e.g. labgrid-dut-proxy librerouter-1 10.13.200.77 22", file=sys.stderr)
        return 1

    _device_id, host, port_str = sys.argv[1], sys.argv[2], sys.argv[3]
    ifname = f"vlan{VLAN_MESH}"

    os.execv(
        LABGRID_BOUND_CONNECT,
        [LABGRID_BOUND_CONNECT, ifname, host, port_str],
    )
    return 0  # unreachable


if __name__ == "__main__":
    sys.exit(main())
