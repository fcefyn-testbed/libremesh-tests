#!/usr/bin/env python3
"""
labgrid-dut-proxy - SSH ProxyCommand for DUT access (isolated / mesh / hybrid).

Reads device map from /etc/labgrid/dut-proxy.yaml (deployed by Ansible per lab).

Mode selection (in priority order):
  1. If the device entry has an 'active' key (emitted by pool-manager in hybrid mode),
     use its vlan/ip directly.  No global mode file is needed.
  2. Otherwise read ~/.config/labgrid-vlan-mode ('isolated' or 'mesh') and select the
     matching entry from the device config.

The 'active' key is written by pool-manager when both pools are in use simultaneously,
so SSH to any DUT works transparently without manually editing labgrid-vlan-mode.

Usage: labgrid-dut-proxy <device-id> <host> <port>
  e.g. labgrid-dut-proxy belkin-2 192.168.1.1 22

Requires: labgrid-bound-connect in /usr/local/sbin/
Sudoers: ALL ALL = NOPASSWD: /usr/local/sbin/labgrid-dut-proxy
"""

import json
import os
import sys

LABGRID_BOUND_CONNECT = "/usr/local/sbin/labgrid-bound-connect"
MODE_FILE = ".config/labgrid-vlan-mode"
CONFIG_PATH = "/etc/labgrid/dut-proxy.yaml"


def get_config_path() -> str | None:
    """Return config path if it exists. Override via LABGRID_DUT_PROXY_CONFIG env."""
    env_path = os.environ.get("LABGRID_DUT_PROXY_CONFIG")
    if env_path and os.path.isfile(env_path):
        return env_path
    if os.path.isfile(CONFIG_PATH):
        return CONFIG_PATH
    return None


def load_config(path: str) -> dict:
    """Load config from YAML or JSON."""
    with open(path, encoding="utf-8") as f:
        content = f.read()
    if path.endswith(".json"):
        return json.loads(content)
    try:
        import yaml
        return yaml.safe_load(content) or {}
    except ImportError:
        raise RuntimeError(
            "YAML config requires PyYAML. Install with: pip install pyyaml"
        ) from None


def get_mode_file_path() -> str:
    """Resolve path to labgrid-vlan-mode (invoking user's home when run via sudo)."""
    real_user = os.environ.get("SUDO_USER")
    if real_user:
        try:
            import pwd
            home = pwd.getpwnam(real_user).pw_dir
        except (KeyError, ImportError):
            home = os.path.expanduser("~")
    else:
        home = os.path.expanduser("~")
    return os.path.join(home, MODE_FILE)


def read_mode() -> str:
    """Read current mode from file. Default to isolated if missing."""
    path = get_mode_file_path()
    try:
        with open(path) as f:
            mode = f.read().strip().lower()
    except OSError:
        mode = "isolated"
    return mode if mode in ("isolated", "mesh") else "isolated"


def main() -> int:
    if len(sys.argv) != 4:
        print("Usage: labgrid-dut-proxy <device-id> <host> <port>", file=sys.stderr)
        print("  e.g. labgrid-dut-proxy belkin-2 192.168.1.1 22", file=sys.stderr)
        return 1

    device_id, _host, port_str = sys.argv[1], sys.argv[2], sys.argv[3]

    config_path = get_config_path()
    if not config_path:
        print(
            f"labgrid-dut-proxy: config not found at {CONFIG_PATH}. "
            "Add ansible/files/exporter/<lab>/dut-proxy.yaml and deploy.",
            file=sys.stderr,
        )
        return 1

    try:
        config = load_config(config_path)
    except Exception as e:
        print(f"labgrid-dut-proxy: failed to load config: {e}", file=sys.stderr)
        return 1

    devices = config.get("devices") or {}
    if device_id not in devices:
        print(f"labgrid-dut-proxy: unknown device '{device_id}'", file=sys.stderr)
        print(f"Known devices: {', '.join(sorted(devices))}", file=sys.stderr)
        return 1

    device_cfg = devices[device_id]

    # Priority 1: explicit 'active' key (written by pool-manager in hybrid mode).
    # This removes the need for a correct global labgrid-vlan-mode when pools are mixed.
    active_cfg = device_cfg.get("active")
    if active_cfg and isinstance(active_cfg, dict) and "vlan" in active_cfg:
        mode_cfg = active_cfg
    else:
        # Priority 2: fall back to global mode file (isolated / mesh).
        mode = read_mode()
        mode_cfg = device_cfg.get(mode)
        if not mode_cfg and len(device_cfg) == 1:
            mode_cfg = next(iter(device_cfg.values()))
        if not mode_cfg:
            print(
                f"labgrid-dut-proxy: no config for device '{device_id}' in mode '{mode}'",
                file=sys.stderr,
            )
            print(f"Available for device: {', '.join(device_cfg)}", file=sys.stderr)
            return 1

    vlan = mode_cfg.get("vlan")
    host = mode_cfg.get("ip", "192.168.1.1")
    if vlan is None:
        print(
            f"labgrid-dut-proxy: missing 'vlan' for device '{device_id}'",
            file=sys.stderr,
        )
        return 1

    ifname = f"vlan{vlan}"

    os.execv(
        LABGRID_BOUND_CONNECT,
        [LABGRID_BOUND_CONNECT, ifname, host, port_str],
    )
    return 0  # unreachable


if __name__ == "__main__":
    sys.exit(main())
